# === Application ===
NODE_ENV=development
PUBLIC_SITE_URL=http://localhost:3000

# === Database (Neon Postgres) ===
# Récupérer depuis console.neon.tech > Project > Connection Details
DATABASE_URL=postgresql://user:pass@host.neon.tech/db?sslmode=require

# === Admin Auth (OBLIGATOIRES en production) ===
# ADMIN_PASSWORD : mot de passe fort pour le dashboard admin
# JWT_SECRET : générer avec `openssl rand -base64 32` ou équivalent
ADMIN_PASSWORD=
JWT_SECRET=

# ADMIN_NAME (optionnel) : nom affiché du compte propriétaire, créé au premier
# démarrage sur une base vierge uniquement. Mettre le nom d'une personne
# (ex: "Gassimou Cissé"), pas le nom de la marque : la sidebar admin distingue
# le branding de l'utilisateur connecté. Défaut : "Administrateur".
ADMIN_NAME=

# === Email transactionnel (Resend) ===
# RESEND_API_KEY : depuis resend.com > API Keys (commence par "re_").
# EMAIL_FROM : adresse d'expéditeur. Avant vérification du domaine chez Resend,
# utiliser "onboarding@resend.dev" (envoi possible uniquement vers l'email du
# compte). Une fois khamci-voyages.com vérifié : "contact@khamci-voyages.com".
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
