# === Application ===
NODE_ENV=development
PUBLIC_SITE_URL=http://localhost:3000

# === Database (Neon Postgres) ===
# Récupérer depuis console.neon.tech > Project > Connection Details
DATABASE_URL=postgresql://user:pass@host.neon.tech/db?sslmode=require

# === Admin Auth (OBLIGATOIRES en production) ===
# ADMIN_PASSWORD : mot de passe fort pour le dashboard admin
# JWT_SECRET : générer avec `openssl rand -base64 32` ou équivalent
ADMIN_PASSWORD=
JWT_SECRET=

# === Email transactionnel (Gmail SMTP) ===
# GMAIL_APP_PASSWORD : mot de passe d'application (pas le mot de passe Google)
# Doc : https://myaccount.google.com/apppasswords
GMAIL_USER=khamcivoyages@gmail.com
GMAIL_APP_PASSWORD=
